generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  director
  floor_manager
  team_lead
  sdr
  leadgen
}

enum LeadStage {
  new
  sequence_active
  replied
  meeting_booked
  won
  lost
}

enum Priority {
  hot
  warm
  cold
}

enum Channel {
  email
  phone
  linkedin
  whatsapp
}

enum TaskType {
  email
  phone
  linkedin
  whatsapp
  manual
}

enum TaskStatus {
  pending
  completed
  skipped
}

enum TaskPriority {
  high
  medium
  low
}

enum ActivityType {
  email_sent
  call_made
  call_logged
  linkedin_sent
  linkedin_touch
  whatsapp_sent
  whatsapp_message
  note_added
  stage_changed
  task_completed
  task_skipped
  lead_created
  meeting_booked
  sequence_enrolled
  sequence_completed
  sequence_unenrolled
  email_task_completed
  lead_reassigned
}

enum ClientStatus {
  active
  paused
  churned
}

enum CampaignStatus {
  active
  paused
  completed
}

enum EmailProvider {
  gmail
  outlook
  imap_smtp
}

enum SequenceEnrollmentStatus {
  active
  paused
  completed
  unenrolled
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(sdr)
  managerId String?
  manager   User?    @relation("UserReports", fields: [managerId], references: [id])
  reports   User[]   @relation("UserReports")
  avatarUrl String?
  timezone  String   @default("UTC")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  assignedLeads  Lead[]         @relation("LeadAssignee")
  tasks          Task[]
  notes          Note[]
  activities     Activity[]
  emailAccounts  EmailAccount[]
  notifications  Notification[]
  reminders      Reminder[]
  sequences      Sequence[]
  templates      Template[]
  campaignSdrs   CampaignSdr[]
  auditLogs      AuditLog[]
  aiMemories     AiMemory[]
  importBatches  ImportBatch[]

  @@index([tenantId])
}

// ─── Clients & Campaigns ─────────────────────────────────────────────────────

model Client {
  id           String       @id @default(cuid())
  name         String
  industry     String
  contactName  String
  contactEmail String
  status       ClientStatus @default(active)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  campaigns Campaign[]

  @@index([tenantId])
}

model Campaign {
  id             String         @id @default(cuid())
  clientId       String
  client         Client         @relation(fields: [clientId], references: [id])
  name           String
  targetVertical String?
  targetGeo      String?
  status         CampaignStatus @default(active)
  startDate      DateTime
  endDate        DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  leads              Lead[]
  campaignSdrs       CampaignSdr[]
  suppressionEntries SuppressionEntry[]
  importBatches      ImportBatch[]

  @@index([tenantId])
}

model CampaignSdr {
  campaignId String
  userId     String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([campaignId, userId])
  @@index([tenantId])
}

// ─── Account (company-level) — Premium Data Model (P8) ──────────────────────

model Account {
  id        String   @id @default(cuid())
  name      String
  industry  String?
  website   String?
  linkedIn  String?
  size      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  leads Lead[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ─── Contact (person-level) — Premium Data Model (P8) ───────────────────────

model Contact {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  company         String
  title           String?
  email           String
  phone           String?
  linkedIn        String?
  whatsApp        String?
  normalizedEmail    String?
  normalizedPhone    String?
  normalizedLinkedIn String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  leadAssignments Lead[]

  @@unique([tenantId, normalizedEmail])
  @@index([tenantId])
}

// ─── Leads (assignment-level) — Premium Data Model (P8) ─────────────────────

model Lead {
  id              String    @id @default(cuid())
  contactId       String?
  contact         Contact?  @relation(fields: [contactId], references: [id])
  firstName       String
  lastName        String
  company         String
  title           String?
  email           String
  phone           String?
  linkedIn        String?
  whatsApp        String?
  accountId       String?
  account         Account?  @relation(fields: [accountId], references: [id])
  stage           LeadStage @default(new)
  assignedToId    String
  assignedTo      User      @relation("LeadAssignee", fields: [assignedToId], references: [id])
  campaignId      String
  campaign        Campaign  @relation(fields: [campaignId], references: [id])
  sequenceId      String?
  sequence        Sequence? @relation(fields: [sequenceId], references: [id])
  sequenceStep    Int?
  sequenceStatus  SequenceEnrollmentStatus?
  timezone        String?
  emailInvalid    Boolean   @default(false)
  source          String?
  tags            String[]
  crmPriorityScore Priority  @default(warm)
  engagementScore Int?
  lastContactedAt DateTime?
  nextTaskDue     DateTime?
  emailSentCount  Int       @default(0)
  emailOpenCount  Int       @default(0)
  emailReplyCount Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  normalizedEmail    String?
  normalizedPhone    String?
  normalizedLinkedIn String?
  archivedAt         DateTime?
  archivedById       String?
  archiveReason      String?

  tasks               Task[]
  notes               Note[]
  activities          Activity[]
  reminders           Reminder[]
  outboundMessages    OutboundMessage[]
  sequenceEnrollments SequenceEnrollment[]
  importRows          ImportRow[]

  @@index([stage])
  @@index([assignedToId])
  @@index([campaignId])
  @@index([accountId])
  @@index([crmPriorityScore])
  @@index([engagementScore])
  @@index([contactId])
  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, assignedToId])
  @@index([tenantId, crmPriorityScore])
  @@index([tenantId, email])
  @@index([campaignId, stage])
  @@index([campaignId, assignedToId])
  @@index([tenantId, archivedAt])
  @@index([tenantId, campaignId, normalizedEmail])
}

// ─── Sequences ───────────────────────────────────────────────────────────────

model Sequence {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  isArchived  Boolean  @default(false)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  steps               SequenceStep[]
  leads               Lead[]
  activities          Activity[]
  sequenceEnrollments SequenceEnrollment[]

  @@index([tenantId])
}

model SequenceStep {
  id           String   @id @default(cuid())
  sequenceId   String
  sequence     Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  order        Int
  channel      Channel
  delayDays    Int      @default(1)
  delayHours   Int      @default(0)
  templateId   String?
  template     Template? @relation(fields: [templateId], references: [id])
  instructions String?
  autoComplete Boolean  @default(false)
  version      Int      @default(1)
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, order])
  @@index([sequenceId])
  @@index([tenantId])
}

// ─── Tasks ───────────────────────────────────────────────────────────────────

model Task {
  id           String       @id @default(cuid())
  leadId       String
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  type         TaskType
  title        String
  description  String?
  outcome      String?
  notes        String?
  dueDate      DateTime
  completedAt  DateTime?
  status       TaskStatus   @default(pending)
  sequenceId   String?
  sequenceStep Int?
  // Soft lock claimed by the auto-send cron; CAS via updateMany since the
  // Neon HTTP driver does not support interactive transactions.
  lockedAt     DateTime?
  priority     TaskPriority @default(medium)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([userId])
  @@index([dueDate])
  @@index([status])
  @@index([tenantId])
  @@index([userId, status, dueDate])
  @@index([leadId, status])
  @@index([type, status, dueDate])
}

// ─── Templates ───────────────────────────────────────────────────────────────

model Template {
  id          String   @id @default(cuid())
  name        String
  channel     Channel
  subject     String?
  body        String
  category    String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sequenceSteps    SequenceStep[]
  abVariants       AbTestVariant[]
  outboundMessages OutboundMessage[]

  @@index([tenantId])
}

model AbTestVariant {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  subject    String?
  body       String?
  version    String   // "A" | "B"
  sentCount  Int      @default(0)
  replyCount Int      @default(0)
  createdAt  DateTime @default(now())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([tenantId])
}

// ─── Notes ───────────────────────────────────────────────────────────────────

model Note {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content     String
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([tenantId])
}

// ─── Reminders ───────────────────────────────────────────────────────────────

model Reminder {
  id          String    @id @default(cuid())
  leadId      String?
  lead        Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  text        String
  dueAt       DateTime
  isDismissed Boolean   @default(false)
  createdAt   DateTime  @default(now())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dueAt])
  @@index([tenantId])
}

// ─── Activities ──────────────────────────────────────────────────────────────

model Activity {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  sequenceId  String?
  sequence    Sequence?    @relation(fields: [sequenceId], references: [id])
  type        ActivityType
  channel     Channel?
  metadata    Json?
  description String?
  createdAt   DateTime     @default(now())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leadId])
  @@index([leadId, type, createdAt])
  @@index([tenantId, userId, type, createdAt])
  @@index([type])
  @@index([createdAt])
  @@index([tenantId])
  @@index([userId, type, createdAt])
}

// ─── Email Accounts ──────────────────────────────────────────────────────────

model EmailAccount {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  email        String
  provider     EmailProvider
  accessToken     String?       @db.Text
  refreshToken    String?       @db.Text
  encAccessToken  String?       @db.Text
  encRefreshToken String?       @db.Text
  tokenExpiry     DateTime?
  imapServer   String?
  imapPort     Int?
  smtpServer   String?
  smtpPort     Int?
  encPassword  String?       @db.Text
  isActive         Boolean       @default(true)
  lastSyncAt       DateTime?
  syncCursor       String?
  dailySendCount   Int           @default(0)
  dailySendDate    DateTime?
  hourlySendWindow Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  tenantId         String
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outboundMessages OutboundMessage[]

  @@index([userId])
  @@index([tenantId])
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String?
  text      String
  linkTo    String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([tenantId])
}

// ─── Audit Logs ──────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String   // e.g. "update_lead", "create_lead", "connect_email"
  tableName     String
  recordId      String
  changedFields Json?    // { "field": { "old": "x", "new": "y" } }
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tableName, recordId])
  @@index([createdAt])
  @@index([tenantId])
}

// ─── Job Runs (durable mirror for BullMQ) ─────────────────────────────────────

model JobRun {
  id           String    @id @default(cuid())
  queueName    String
  jobName      String
  bullJobId    String?
  dedupeKey    String    @unique
  status       String    @default("queued") // queued | active | completed | failed
  progress     Json?
  result       Json?
  failedReason String?
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  enqueuedAt   DateTime  @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([queueName, status])
  @@index([dedupeKey])
  @@index([tenantId])
}

// ─── Outbound Messages ───────────────────────────────────────────────────────

model OutboundMessage {
  id                String        @id @default(cuid())
  leadId            String
  lead              Lead          @relation(fields: [leadId], references: [id])
  accountId         String
  account           EmailAccount  @relation(fields: [accountId], references: [id])
  templateId        String?
  template          Template?     @relation(fields: [templateId], references: [id])
  to                String
  subject           String?
  body              String?
  providerMessageId String?
  idempotencyKey    String        @unique
  status            String        @default("pending") // pending | sending | sent | failed | bounced
  errorMessage      String?
  sentAt            DateTime?
  openedAt          DateTime?
  repliedAt         DateTime?
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([leadId])
  @@index([accountId])
  @@index([status])
  @@index([idempotencyKey])
  @@index([providerMessageId])
  @@index([tenantId])
}

// ─── Suppression Entries ─────────────────────────────────────────────────────

model SuppressionEntry {
  id         String    @id @default(cuid())
  email      String?
  domain     String?
  company    String?
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  reason     String    // hard_bounce | spam | manual | unsubscribed
  createdAt  DateTime  @default(now())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([domain])
  @@index([campaignId])
  @@index([tenantId])
  @@unique([tenantId, email, campaignId])
  @@unique([tenantId, domain, campaignId])
  @@unique([tenantId, company, campaignId])
}

// ─── Sequence Enrollments ────────────────────────────────────────────────────

model SequenceEnrollment {
  id           String                    @id @default(cuid())
  leadId       String
  lead         Lead                      @relation(fields: [leadId], references: [id])
  sequenceId   String
  sequence     Sequence                  @relation(fields: [sequenceId], references: [id])
  status       SequenceEnrollmentStatus  @default(active)
  currentStep  Int                       @default(1)
  startedAt    DateTime                  @default(now())
  completedAt  DateTime?
  tenantId     String
  tenant       Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([sequenceId])
  @@index([status])
  @@index([tenantId])
}

// ─── Import ──────────────────────────────────────────────────────────────────

model ImportBatch {
  id         String    @id @default(cuid())
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  filename   String?
  totalRows  Int       @default(0)
  parsedRows Int       @default(0)
  errorRows  Int       @default(0)
  status     String    @default("pending") // pending | parsing | parsed | committing | committed | failed
  errorFile  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  importRows ImportRow[]

  @@index([campaignId])
  @@index([userId])
  @@index([status])
  @@index([tenantId])
}

model ImportRow {
  id        String   @id @default(cuid())
  batchId   String
  batch     ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  rowIndex  Int
  data      Json
  errors    Json?
  status    String   @default("pending") // pending | valid | error | imported
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([status])
  @@index([tenantId])
}

// ─── AI SDR Assistant — Per-User Memory ─────────────────────────────────────

model AiMemory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memory    String
  createdAt DateTime @default(now())
  tenantId  String

  @@index([userId])
  @@index([tenantId])
}

// ─── Tenant ──────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  clients            Client[]
  campaigns          Campaign[]
  campaignSdrs       CampaignSdr[]
  accounts           Account[]
  contacts           Contact[]
  leads              Lead[]
  sequences          Sequence[]
  sequenceSteps      SequenceStep[]
  tasks              Task[]
  templates          Template[]
  abVariants         AbTestVariant[]
  notes              Note[]
  reminders          Reminder[]
  activities         Activity[]
  emailAccounts      EmailAccount[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  jobRuns            JobRun[]
  outboundMessages   OutboundMessage[]
  suppressionEntries SuppressionEntry[]
  sequenceEnrollments SequenceEnrollment[]
  importBatches      ImportBatch[]
  importRows         ImportRow[]
}

