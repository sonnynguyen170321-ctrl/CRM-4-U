{
  "name": "telestar-sdr-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint app components lib context tests",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "analyze": "ANALYZE=true next build",
    "worker:dev": "node scripts/worker-dev.cjs",
    "worker:start": "node scripts/worker-start.cjs",
    "worker:healthcheck": "tsx -e \"require('dotenv').config(); const {enqueue,JobType}=require('./lib/bullmq'); enqueue(JobType.MAINTENANCE_HEALTHCHECK,{startedAt:new Date().toISOString()}).then(id=>console.log('enqueued',id)).catch(console.error)\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@next/bundle-analyzer": "^16.2.9",
