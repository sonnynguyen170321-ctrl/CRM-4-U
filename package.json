    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.1",
    "googleapis": "^173.0.0",
    "groq-sdk": "^1.2.1",
    "imapflow": "^1.3.5",
    "inngest": "^4.5.1",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^8.0.10",
    "prisma": "^6.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "sip.js": "^0.21.2",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
