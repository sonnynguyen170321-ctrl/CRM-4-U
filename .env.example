# ─── Database Connection ──────────────────────────────────────────────────────
# Standard PostgreSQL. Works with any Postgres — local, AWS RDS, Supabase, etc.
# DATABASE_URL is the app's pooled/runtime connection; DIRECT_URL is used by Prisma
# migrations (`prisma migrate deploy`). For a single Postgres they can be identical.
#
# Local development:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/telestar_crm"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/telestar_crm"
#
# Production (e.g. AWS RDS — require TLS):
# DATABASE_URL="postgresql://[user]:[password]@[rds-endpoint]:5432/telestar_crm?sslmode=require"
# DIRECT_URL="postgresql://[user]:[password]@[rds-endpoint]:5432/telestar_crm?sslmode=require"

# Set to "true" ONLY after applying supabase/rls.sql (Postgres-level Row-Level Security).
# When true, each query also sets the RLS GUCs inside a transaction (defense-in-depth).
# Leave unset/false otherwise: the app-layer tenant scoping is the isolation layer.
# DB_RLS_ENFORCED="false"

# ─── NextAuth Settings ────────────────────────────────────────────────────────
# Generate a secret via: openssl rand -base64 32   (use a FRESH value in production)
AUTH_SECRET="your_nextauth_auth_secret_here"
# Set to the public app URL in production, e.g. https://crm.yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# ─── Credential Encryption ───────────────────────────────────────────────────
# AES-256 key for encrypting IMAP/SMTP passwords + OAuth tokens at rest.
# Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your_64_char_hex_key_here"

# ─── First admin (production) ─────────────────────────────────────────────────
# Production must NOT run `npm run db:seed` (that creates demo users with a shared
# password). Instead create the first Director with: npm run create-admin
# (reads these, or pass --email / --password / --name flags):
# ADMIN_EMAIL="you@yourdomain.com"
# ADMIN_PASSWORD="a-strong-password"
# ADMIN_NAME="Your Name"

# ─── Google Gmail OAuth (optional) ────────────────────────────────────────────
# Google Developer Console: https://console.cloud.google.com  (set redirect URI to the prod domain)
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/email/oauth/google/callback"

# ─── Microsoft Outlook OAuth (optional) ───────────────────────────────────────
# Azure AD Portal: https://portal.azure.com  (set redirect URI to the prod domain)
MICROSOFT_CLIENT_ID="your_microsoft_client_id_here"
MICROSOFT_CLIENT_SECRET="your_microsoft_client_secret_here"
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/email/oauth/microsoft/callback"

# ─── AI SDR Assistant (optional) ──────────────────────────────────────────────
# Groq is primary, Gemini the rate-limit fallback (lib/ai/provider.ts). With neither
# key the assistant degrades to a friendly "unavailable" message.
# Groq: https://console.groq.com/keys   ·   Gemini: https://aistudio.google.com/apikey
GROQ_API_KEY="your_groq_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"

# ─── BullMQ / Redis (workers + optional cache) ────────────────────────────────
# Required on the always-on WORKER host (npm run worker:start). The web app uses it as
# an optional cache and degrades gracefully if absent. Local dev: redis://localhost:6379.
# Production: managed Redis (ElastiCache / Upstash / Redis Cloud). Use rediss:// for TLS.
REDIS_URL="redis://localhost:6379"

# ─── Sequence Automation Crons ────────────────────────────────────────────────
# Bearer token the host scheduler (PM2 / OS cron) sends to /api/cron/* routes.
# Generate via: openssl rand -hex 32
#   curl -H "Authorization: Bearer $CRON_SECRET" https://your-host/api/cron/sequence-engine
CRON_SECRET="your_cron_secret_here"
# Global kill switch for unattended sequence email sending ("false" disables live sends).
SEQUENCE_AUTOSEND_ENABLED="true"
