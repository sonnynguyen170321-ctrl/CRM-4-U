# ─── Database Connection ──────────────────────────────────────────────────────
# Neon.tech: use the pooled connection string (pgBouncer) for DATABASE_URL
# and the direct connection string for DIRECT_URL (used by Prisma migrations).
# Both are found in Neon Console → Connection Details → Connection string.
#
# Neon pooled (pgBouncer, for app runtime — add ?pgbouncer=true&connection_limit=1):
DATABASE_URL="postgresql://[user]:[password]@[host]-pooler.neon.tech/[dbname]?sslmode=require&pgbouncer=true&connection_limit=1"
# Neon direct (for Prisma migrate — no pgBouncer):
DIRECT_URL="postgresql://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require"
#
# Local development fallback:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/telestar_crm"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/telestar_crm"

# Set to "true" ONLY after applying supabase/rls.sql to the target DB (Postgres-level
# Row-Level Security). When true, each query also sets the RLS GUCs inside a transaction
# (defense-in-depth). Leave unset/false on Neon: the app-layer tenant scoping is the
# isolation layer and queries run as single fast HTTP statements.
# DB_RLS_ENFORCED="false"

# ─── NextAuth Settings ────────────────────────────────────────────────────────
# Generate a secret via: openssl rand -base64 32
AUTH_SECRET="your_nextauth_auth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Google Gmail OAuth ───────────────────────────────────────────────────────
# Get these from Google Developer Console (https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/email/oauth/google/callback"

# ─── Microsoft Outlook OAuth ──────────────────────────────────────────────────
# Get these from Azure Active Directory Portal (https://portal.azure.com)
MICROSOFT_CLIENT_ID="your_microsoft_client_id_here"
MICROSOFT_CLIENT_SECRET="your_microsoft_client_secret_here"
MICROSOFT_REDIRECT_URI="http://localhost:3000/api/email/oauth/microsoft/callback"

# ─── Credential Encryption ───────────────────────────────────────────────────
# AES-256 key for encrypting IMAP/SMTP passwords at rest.
# Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your_64_char_hex_key_here"

# ─── AI SDR Assistant ─────────────────────────────────────────────────────────
# The in-app AI assistant uses Groq as the primary provider and Gemini as the
# rate-limit fallback (lib/ai/provider.ts). Set at least GROQ_API_KEY, or the
# assistant returns a friendly "unavailable" message.
# Groq: https://console.groq.com/keys   ·   Gemini: https://aistudio.google.com/apikey
GROQ_API_KEY="your_groq_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"

# ─── BullMQ / Redis ────────────────────────────────────────────────────────────
# Redis connection string for BullMQ queues. Local dev: redis://localhost:6379.
# Production: managed Redis (Upstash / Redis Cloud / ElastiCache).
# Use rediss:// for TLS-enabled Redis.
REDIS_URL="redis://localhost:6379"

# ----- Sequence Automation Crons -----
# Bearer token Vercel Cron sends to /api/cron/* routes. Set the same value in
# Vercel project env vars. Generate via: openssl rand -hex 32
CRON_SECRET="your_cron_secret_here"
# Global kill switch for unattended sequence email sending ("false" disables)
SEQUENCE_AUTOSEND_ENABLED="true"
